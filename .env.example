# Copy to .env for local dev, or set these in the Render dashboard.
# Leave Google vars unset to run in demo mode (local/seed data, no sync).

# Google OAuth (https://console.cloud.google.com -> Credentials -> OAuth client)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local:  http://localhost:3001/api/auth/google/callback
# Render: https://<your-app>.onrender.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
GOOGLE_SHEET_ID=your-google-sheet-id

# Session signing secret (Render can auto-generate this)
SESSION_SECRET=change-this-secret

# Where the browser loads the app.
# Local: http://localhost:5173   Render (single service): https://<your-app>.onrender.com
FRONTEND_ORIGIN=http://localhost:5173

# Role mapping by email (comma-separated)
PACWIN_ADMIN_EMAILS=admin@pacwinindia.com
PACWIN_MANAGER_EMAILS=manager@pacwinindia.com
PACWIN_MEMBER_EMAILS=member@pacwinindia.com

# Team members OUTSIDE @pacwinindia.com who may still sign in (comma-separated)
EXTRA_ALLOWED_EMAILS=

# Email notifications (assignment / updates). Sender = a Workspace mailbox with
# 2-Step Verification + a generated App Password. Leave blank to disable email.
GMAIL_USER=sandhya@pacwinindia.com
GMAIL_APP_PASSWORD=

# Optional: enables real LLM profile insights (otherwise rule-based is used)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: server port (Render sets PORT automatically)
# PORT=3001
